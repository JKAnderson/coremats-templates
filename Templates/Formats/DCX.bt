// File Mask: *.dcx
//  ID Bytes: 44 43 58 00
//   History: 
//------------------------------------------------

#include "../Common.bt"

BigEndian();

//------------------------------------------------

typedef struct {
    char magic[4]; Assert(magic == "DCX\0");
    int unk04 <format=hex>;
    int dcsOffset <format=hex>;
    int dcpOffset <format=hex>;
    // In games before BB (approximately), these offsets are 0x20 smaller than you'd expect
    // Some games do use them and account for that, so the discrepancy needs to be preserved
    int dcaOffset <format=hex>;
    int dataOffset <format=hex>;
} Dcx <bgcolor=cLtRed>;


typedef struct {
    char magic[4]; Assert(magic == "DCS\0");
    int dataLengthUncompressed <format=hex>;
    // For EDGE, this does include the padding between blocks
    int dataLengthCompressed <format=hex>;
} Dcs <bgcolor=cLtGreen>;


typedef struct {
    char magic[4]; Assert(magic == "DCP\0");
    char algorithm[4];
    int dcpSize <format=hex>; Assert(dcpSize == 0x20);
    byte level;
    byte seekChunkReset; Assert(seekChunkReset == 0);
    short unk0e <hidden=true>; Assert(!unk0e);
    int blockSize <format=hex>;
    byte header;
    byte unk15 <hidden=true>; Assert(!unk15);
    short unk16 <hidden=true>; Assert(!unk16);
    int unk18 <hidden=true>; Assert(!unk18);
    short alignSize <format=hex>;
    short unk1e <format=hex>; Assert(unk1e == 0x100);
} Dcp <bgcolor=cAqua>;


typedef struct {
    char magic[4]; Assert(magic == "DCA\0");
    int dcaSize <format=hex>;
    if (dcp.algorithm == "EDGE") {
        struct {
            char magic[4]; Assert(magic == "EgdT");
            int unk04 <format=hex>; Assert(unk04 == 0x10100);
            int unk08 <format=hex>; Assert(unk08 == 0x24);
            int unk0c <format=hex>; Assert(unk0c == 0x10);
            int unk10 <format=hex>; Assert(unk10 == 0x10000);
            // If the file is an exact multiple of the block size, this is the block size, not 0
            int trailingBlockLengthUncompressed <format=hex>;
            int egdtSize <format=hex>;
            int blockCount;
            int unk20 <format=hex>; Assert(unk20 == 0x100000);
            
            struct {
                int unk00 <hidden=true>; Assert(!unk00);
                int dataOffset <format=hex>;
                int dataLength <format=hex>;
                int compressed; Assert(IsBool(compressed));
            } blockInfo[blockCount] <optimize=false, bgcolor=cDkYellow>;
        } egdt <bgcolor=cYellow>;
    }
} Dca <bgcolor=cLtYellow>;

//------------------------------------------------

Dcx dcx;
Dcs dcs;
Dcp dcp;
Dca dca;
ubyte data[dcs.dataLengthCompressed] <bgcolor=cBlack>;
